# Copy this file to ".env" and fill in your own values. Do NOT commit ".env".
# FRED (St. Louis Fed) API key — get a free key at https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_api_key_here

# LLM provider for the M1 market report: anthropic | ollama | stub | auto
#   ollama = free local model (install Ollama, `ollama pull qwen2.5:3b`), data stays local
#   anthropic = Claude API (paid, needs ANTHROPIC_API_KEY)
#   stub = no LLM, deterministic placeholder
LLM_PROVIDER=stub
OLLAMA_MODEL=qwen2.5:3b

# Anthropic API key for the LLM market report (M1). Leave blank to use stub mode.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional model override
